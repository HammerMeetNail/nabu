# Choresy Environment Variables
# Copy to .env and fill in values

# Server
PORT=8080
APP_ENV=development
APP_BASE_URL=http://localhost:8080
SERVER_SECURE=false

# PostgreSQL
DATABASE_URL=postgres://choresy:choresy@localhost:5432/choresy?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Session & CSRF (generated securely in production)
SESSION_SECRET=
CSRF_SECRET=

# SMTP Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# VAPID (Web Push)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=

# Trusted proxy CIDRs (comma-separated)
TRUSTED_PROXY_CIDRS=

# Backup (Cloudflare R2)
R2_BUCKET=choresy-backups
BACKUP_ENCRYPTION_KEY=
BACKUP_NOTIFY_EMAILS=
BACKUP_NOTIFY_SUCCESS=1
BACKUP_NOTIFY_VERIFY_SUCCESS=0
