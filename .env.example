# Nabu Environment Variables
# Copy to .env and fill in values

# Server
PORT=8080
APP_ENV=development
APP_BASE_URL=http://localhost:8080
SERVER_SECURE=false

# PostgreSQL
DATABASE_URL=postgres://nabu:nabu@localhost:5432/nabu?sslmode=disable

# SMTP Email (uses Resend SMTP relay)
SMTP_PASS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Trusted proxy CIDRs (comma-separated).
# REQUIRED in production behind a reverse proxy / Cloudflare Tunnel: without it,
# every request appears to come from the proxy IP, so per-client rate limiting
# collapses into one shared bucket and audit-log client IPs are meaningless.
# Set to your proxy/tunnel CIDR ranges (e.g. Cloudflare's published ranges, or
# the tunnel/loopback address). The server logs a startup warning if this is
# empty while APP_ENV=production.
TRUSTED_PROXY_CIDRS=

# Rate limiting (requests per minute, per client IP, per path)
# RATE_LIMIT_AUTH_MAX: strict limit on /api/auth/* (default 5)
# RATE_LIMIT_GLOBAL_MAX: permissive backstop across all /api/* routes (default 120)
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_GLOBAL_MAX=120

# Backup (Cloudflare R2)
R2_BUCKET=nabu-app-backups
BACKUP_ENCRYPTION_KEY=
BACKUP_NOTIFY_EMAILS=
BACKUP_NOTIFY_SUCCESS=1
BACKUP_NOTIFY_VERIFY_SUCCESS=0
