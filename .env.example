# Nabu Environment Variables
# Copy to .env and fill in values

# Server
PORT=8080
APP_ENV=development
APP_BASE_URL=http://localhost:8080
SERVER_SECURE=false

# PostgreSQL
DATABASE_URL=postgres://nabu:nabu@localhost:5432/nabu?sslmode=disable

# SMTP Email (uses Resend SMTP relay)
SMTP_PASS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Trusted proxy CIDRs (comma-separated)
TRUSTED_PROXY_CIDRS=

# Backup (Cloudflare R2)
R2_BUCKET=nabu-app-backups
BACKUP_ENCRYPTION_KEY=
BACKUP_NOTIFY_EMAILS=
BACKUP_NOTIFY_SUCCESS=1
BACKUP_NOTIFY_VERIFY_SUCCESS=0
